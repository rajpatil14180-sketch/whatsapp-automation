# Server
PORT=3000

# Meta / WhatsApp webhook
META_VERIFY_TOKEN=choose-any-secret-string     # you invent this; paste the same value into the Meta dashboard
META_APP_SECRET=your-meta-app-secret           # from the Meta app settings (enables signature verification)
GRAPH_VERSION=v21.0

# Supabase (service role key — server-side only, never ship to a browser)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5                 # or claude-haiku-4-5-20251001 for cheaper at scale

# Operator alerts
OPERATOR_WA=918888888888                        # global fallback operator WhatsApp (digits, E.164 no '+') if a tenant has no operator_wa

# Stats endpoint (GET /stats?token=...) — endpoint is disabled if unset
STATS_TOKEN=choose-a-long-random-string

# OPTIONAL token encryption (AES-256-GCM). 64 hex chars (32 bytes). If unset, tokens stay plaintext.
# ⚠️ If you enable this and later lose the key, ALL stored tenant tokens become unreadable. Back it up.
#ENCRYPTION_KEY=

# Circuit breakers (optional; defaults shown)
#TENANT_DAILY_TEMPLATE_CAP=250                  # max template sends per tenant per day
#CLAUDE_CALLS_PER_MINUTE=30                     # global cap on brain (Claude) calls per minute
